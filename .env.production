# BillGenie Restaurant API — Production (Fly.io)
# Secrets are NOT stored in git. Set via: .\scripts\set-fly-secrets.ps1
# Template reference: scripts\fly-secrets.example.env

# ================================================
# PRODUCTION URLS
# ================================================
API_BASE_URL=https://billgenie-api.fly.dev
# Health: https://billgenie-api.fly.dev/health
# WebSocket: wss://billgenie-api.fly.dev/ws

# ================================================
# DATABASE (DigitalOcean Managed Postgres — blr1)
# ================================================
DATABASE_URL=postgresql://doadmin:YOUR_PASSWORD@db-postgresql-blr1-XXXXX.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# ================================================
# REDIS (Upstash — ap-south-1, TLS)
# ================================================
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR-ENDPOINT.upstash.io:6379

# ================================================
# SERVER (Fly.io sets PORT=3000 in fly.toml)
# ================================================
PORT=3000
SERVER_PORT=3000
SERVER_ENV=production
LOG_LEVEL=info

# ================================================
# JWT — generate fresh secrets for production
# ================================================
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=REPLACE_WITH_32_BYTE_SECRET
REFRESH_JWT_SECRET=REPLACE_WITH_ANOTHER_32_BYTE_SECRET
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h

# ================================================
# CORS — tighten after pilot (* is OK for testing)
# ================================================
CORS_ALLOWED_ORIGINS=*

# ================================================
# FEATURES
# ================================================
ENABLE_PAYMENT=true
ENABLE_WEBSOCKET=true
ENABLE_LOGGING=true

# ================================================
# OPTIONAL
# ================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
