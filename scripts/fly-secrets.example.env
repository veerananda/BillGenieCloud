# Copy to fly-secrets.env (gitignored) and fill in values, then run:
#   .\scripts\set-fly-secrets.ps1

# DigitalOcean Managed Postgres (region: blr1)
# Copy URI from DO console → Connection details → "Connection string" → show password
# If password has special chars (@ # % &), URL-encode them in the URI (e.g. @ → %40)
DATABASE_URL=postgresql://doadmin:YOUR_PASSWORD@db-postgresql-blr1-XXXXX.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Upstash Redis (TLS)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR-ENDPOINT.upstash.io:6379

# Generate with: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
JWT_SECRET=REPLACE_WITH_32_BYTE_SECRET
REFRESH_JWT_SECRET=REPLACE_WITH_ANOTHER_32_BYTE_SECRET

# Public API URL (update after first deploy if app name differs)
API_BASE_URL=https://billgenie-api.fly.dev

# Comma-separated origins; use * for pilot, tighten later
CORS_ALLOWED_ORIGINS=*

# Optional
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# BillGenie Platform Console (creators only) — generate a long random string
PLATFORM_OPS_API_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
